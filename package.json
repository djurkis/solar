{
    "name": "windy-plugin-eu-solar",
    "version": "2.1.0",
    "description": "Windy plugin visualizing 10,000+ utility-scale solar PV plants (49 GW) across CZ, DE, PL, AT, SK, HU with H3 hexagonal density overlay",
    "main": "dist/plugin.min.js",
    "type": "module",
    "scripts": {
        "build": "rm -rf dist && mkdir dist && SERVE=false rollup -c && cp package.json dist/",
        "build:win": "rmdir /s /q dist && mkdir dist && set SERVE=false && rollup -c && copy package.json dist\\",
        "start": "rollup -w -c",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jurkis/windy-plugin-eu-solar.git"
    },
    "keywords": [
        "windy",
        "windy.com",
        "plugin",
        "solar",
        "photovoltaic",
        "h3",
        "energy",
        "central-europe"
    ],
    "author": "jurkis",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/jurkis/windy-plugin-eu-solar/issues"
    },
    "homepage": "https://github.com/jurkis/windy-plugin-eu-solar#readme",
    "dependencies": {
        "@windycom/plugin-devtools": "^1.0.6"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "less": "^4.6.4",
        "rollup": "^3.30.0",
        "rollup-plugin-cleanup": "^3.2.1",
        "rollup-plugin-serve": "^3.0.0",
        "rollup-plugin-svelte": "^7.2.3",
        "rollup-plugin-swc3": "^0.12.1",
        "svelte": "^4.2.20",
        "svelte-preprocess": "^6.0.3",
        "svelte-preprocess-less": "^0.4.0",
        "typescript": "^5.9.3"
    }
}
